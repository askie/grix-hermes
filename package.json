{
  "name": "@dhf-hermes/grix",
  "version": "0.2.4",
  "description": "Standalone Hermes skill bundle for Grix workflows.",
  "type": "module",
  "bin": {
    "grix-hermes": "bin/grix-hermes.js"
  },
  "files": [
    "bin/**/*.js",
    "lib/**/*.js",
    "shared/**/*.js",
    "grix-admin/**/*.js",
    "grix-admin/SKILL.md",
    "grix-admin/agents/**",
    "grix-admin/references/**",
    "grix-egg/**/*.js",
    "grix-egg/SKILL.md",
    "grix-egg/agents/**",
    "grix-egg/references/**",
    "grix-group/**/*.js",
    "grix-group/SKILL.md",
    "grix-group/agents/**",
    "grix-query/**/*.js",
    "grix-query/SKILL.md",
    "grix-query/agents/**",
    "grix-register/**/*.js",
    "grix-register/SKILL.md",
    "grix-register/agents/**",
    "grix-register/references/**",
    "grix-update/**/*.js",
    "grix-update/SKILL.md",
    "grix-update/agents/**",
    "grix-update/references/**",
    "message-send/**/*.js",
    "message-send/SKILL.md",
    "message-send/agents/**",
    "message-unsend/**/*.js",
    "message-unsend/SKILL.md",
    "message-unsend/agents/**",
    "README.md",
    "LICENSE",
    ".gitignore"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "node ./scripts/clean_build.mjs",
    "list": "node ./bin/grix-hermes.js list",
    "manifest": "node ./bin/grix-hermes.js manifest",
    "test": "npm run build && node --test tests/*.test.js",
    "test:watch": "tsx --test tests/*.test.ts",
    "prepack": "npm run clean && npm run build",
    "publish:preview": "bash ./publish.sh",
    "publish:npm": "bash ./publish.sh --publish"
  },
  "keywords": [
    "hermes",
    "skills",
    "grix"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
